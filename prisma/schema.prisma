generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model Community {
  id               String        @id @default(cuid())
  name             String        @db.VarChar(100)
  slug             String        @unique @db.VarChar(120)
  description      String        @db.Text
  shortDescription String?       @db.VarChar(255)
  logo             String?       @db.VarChar(255)
  coverImage       String?       @db.VarChar(255)
  themeColor       String?       @db.VarChar(30)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  events           Event[]
  galleries        Gallery[]
  testimonials     Testimonial[]

  @@index([slug])
}

model Testimonial {
  id String @id @default(cuid())

  name        String  @db.VarChar(100)
  designation String? @db.VarChar(100)

  image   String? @db.VarChar(255)
  message String  @db.Text

  communityId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  community Community? @relation(fields: [communityId], references: [id])

  @@index([communityId])
}

model Event {
  id          String @id @default(cuid())
  communityId String

  title String @db.VarChar(150)
  slug  String @unique @db.VarChar(180)

  shortDescription String? @db.VarChar(255)
  description      String  @db.Text

  categoryId Int?
  category   Category? @relation(fields: [categoryId], references: [id])

  eventDate DateTime
  eventTime String   @db.VarChar(50)
  endTime   String?  @db.VarChar(50)

  location       String  @db.VarChar(255)
  googleMapsLink String? @db.Text

  price Decimal @default(0.00) @db.Decimal(10, 2)

  coverImage    String? @db.VarChar(255)
  galleryImages Json?

  maxParticipants      Int?
  registrationDeadline DateTime?

  status   EventStatus @default(DRAFT)
  featured Boolean     @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  community     Community      @relation(fields: [communityId], references: [id], onDelete: Cascade)
  galleries     Gallery[]
  registrations Registration[]

  @@index([communityId])
  @@index([categoryId])
  @@index([slug])
  @@index([status])
  @@index([eventDate])
  @@index([featured])
}

model Registration {
  id                 String             @id @default(cuid())
  eventId            String
  fullName           String             @db.VarChar(100)
  email              String             @db.VarChar(100)
  phone              String             @db.VarChar(20)
  gender             String?            @db.VarChar(20)
  age                Int?
  city               String?            @db.VarChar(100)
  emergencyContact   String?            @db.VarChar(50)
  notes              String?            @db.Text
  paymentStatus      PaymentStatus      @default(PENDING)
  registrationStatus RegistrationStatus @default(PENDING)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  checkedInAt        DateTime?
  event              Event              @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([eventId, email])
  @@index([eventId])
  @@index([email])
  @@index([phone])
  @@index([paymentStatus])
  @@index([registrationStatus])
}

model Admin {
  id           String    @id @default(cuid())
  name         String    @db.VarChar(100)
  email        String    @unique @db.VarChar(100)
  password     String    @db.VarChar(255)
  role         AdminRole @default(EDITOR)
  profileImage String?   @db.VarChar(255)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([email])
}

model Gallery {
  id          String     @id @default(cuid())
  eventId     String?
  communityId String?
  imageUrl    String     @db.VarChar(255)
  caption     String?    @db.VarChar(255)
  uploadedBy  String?    @db.VarChar(100)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  community   Community? @relation(fields: [communityId], references: [id])
  event       Event?     @relation(fields: [eventId], references: [id])

  @@index([eventId])
  @@index([communityId])
}

model ContactSubmission {
  id        String   @id @default(cuid())
  name      String   @db.VarChar(100)
  email     String   @db.VarChar(100)
  phone     String   @db.VarChar(20)
  message   String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
  @@index([createdAt])
}

model Settings {
  id            String   @id @default(cuid())
  siteName      String   @default("Awaken Circle") @db.VarChar(100)
  logo          String?  @db.VarChar(255)
  instagramLink String?  @db.VarChar(255)
  whatsappLink  String?  @db.VarChar(255)
  youtubeLink   String?  @db.VarChar(255)
  email         String?  @db.VarChar(100)
  phone         String?  @db.VarChar(20)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Category {
  id Int @id @default(autoincrement())

  name String  @unique @db.VarChar(100)
  slug String  @unique @db.VarChar(120)
  icon String? @db.VarChar(255)

  events Event[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum EventStatus {
  DRAFT
  PUBLISHED
  CANCELLED
  COMPLETED
}

enum PaymentStatus {
  PENDING
  PAID
  REFUNDED
  FAILED
  FREE
}

enum RegistrationStatus {
  PENDING
  CONFIRMED
  CHECKED_IN
  ATTENDED
  CANCELLED
}

enum AdminRole {
  SUPERADMIN
  ADMIN
  EDITOR
}
